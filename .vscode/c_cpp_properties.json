{
    "configurations": [
        {
            "name": "ESP-IDF",
            "compilerPath": "${config:idf.toolsPathWin}/tools/xtensa-esp-elf/esp-14.2.0_20250730/xtensa-esp-elf/bin/xtensa-esp32s3-elf-gcc.exe",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "includePath": [
                "${workspaceFolder}/**",
                "${config:idf.espIdfPathWin}/components/**",
                "${workspaceFolder}/build/config"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${config:idf.espIdfPathWin}/components"
                ],
                "limitSymbolsToIncludedHeaders": false
            },
            "defines": [
                "ESP_PLATFORM",
                "IDF_VER=\"v5.5.0\"",
                "SOC_MMU_PAGE_SIZE=CONFIG_MMU_PAGE_SIZE",
                "CONFIG_IDF_TARGET_ESP32S3=1",
                "_GNU_SOURCE"
            ],
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x86"
        },
        {
            "name": "Simulator",
            "includePath": [
                "${workspaceFolder}/main/include/**",
                "${workspaceFolder}/main/src/**",
                "${workspaceFolder}/simulator/include/**",
                "${workspaceFolder}/components/lvgl__lvgl/**",
                "${workspaceFolder}/components/cjson/**"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "LV_CONF_INCLUDE_SIMPLE",
                "SIMULATOR_BUILD"
            ],
            "windowsSdkVersion": "10.0.22621.0",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-msvc-x64"
        }
    ],
    "version": 4
}
